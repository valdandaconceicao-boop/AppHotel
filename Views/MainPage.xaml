<?xml version="1.0" encoding="UTF-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppHotel.Views.MainPage"
             Title="App Hotel"
             BackgroundColor="White">

    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="30">

            <Label Text="App Hotel - Reservas"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="Black"
                   HorizontalOptions="Center" />

            <Label Text="Preencha os dados abaixo para simular sua reserva."
                   FontSize="16"
                   TextColor="#666666"
                   HorizontalOptions="Center" />

            <!-- Dados do Hóspede -->
            <Label Text="Dados do Hóspede" FontSize="18" FontAttributes="Bold" TextColor="Black" Margin="0,15,0,0"/>
            
            <Entry Placeholder="Nome completo *" Text="{Binding Nome}" TextColor="Black" BackgroundColor="Transparent" />
            <Entry Placeholder="E-mail" Text="{Binding Email}" Keyboard="Email" TextColor="Black" BackgroundColor="Transparent" />
            <Entry Placeholder="Telefone" Text="{Binding Telefone}" Keyboard="Telephone" TextColor="Black" BackgroundColor="Transparent" />

            <!-- Período da Estadia -->
            <Label Text="Período da Estadia" FontSize="18" FontAttributes="Bold" TextColor="Black" Margin="0,15,0,0"/>
            
            <Grid ColumnDefinitions="100, *" RowDefinitions="Auto, Auto" RowSpacing="15">
                <Label Text="Check-in:" VerticalOptions="Center" TextColor="Black" Grid.Row="0" Grid.Column="0" />
                <DatePicker Date="{Binding DataCheckIn}" MinimumDate="{Binding DataMinima}" TextColor="Black" Grid.Row="0" Grid.Column="1" HorizontalOptions="Fill" />

                <Label Text="Check-out:" VerticalOptions="Center" TextColor="Black" Grid.Row="1" Grid.Column="0" />
                <DatePicker Date="{Binding DataCheckOut}" MinimumDate="{Binding DataMinimaSaida}" TextColor="Black" Grid.Row="1" Grid.Column="1" HorizontalOptions="Fill" />
            </Grid>

            <!-- Hóspedes -->
            <Label Text="Quantidade de Hóspedes" FontSize="18" FontAttributes="Bold" TextColor="Black" Margin="0,15,0,0"/>
            
            <Grid ColumnDefinitions="100, 50, *" RowDefinitions="Auto, Auto" RowSpacing="15">
                <Label Text="Adultos:" VerticalOptions="Center" TextColor="Black" Grid.Row="0" Grid.Column="0" />
                <Label Text="{Binding QuantidadeAdultos}" VerticalOptions="Center" FontAttributes="Bold" TextColor="Black" FontSize="16" Grid.Row="0" Grid.Column="1" />
                <Stepper Value="{Binding QuantidadeAdultos}" Minimum="1" Maximum="10" Grid.Row="0" Grid.Column="2" HorizontalOptions="Start" />

                <Label Text="Crianças:" VerticalOptions="Center" TextColor="Black" Grid.Row="1" Grid.Column="0" />
                <Label Text="{Binding QuantidadeCriancas}" VerticalOptions="Center" FontAttributes="Bold" TextColor="Black" FontSize="16" Grid.Row="1" Grid.Column="1" />
                <Stepper Value="{Binding QuantidadeCriancas}" Minimum="0" Maximum="5" Grid.Row="1" Grid.Column="2" HorizontalOptions="Start" />
            </Grid>

            <!-- Tipo de Quarto -->
            <Label Text="Tipo de Quarto" FontSize="18" FontAttributes="Bold" TextColor="Black" Margin="0,15,0,0"/>
            
            <Picker Title="Selecione uma opção *"
                    ItemsSource="{Binding ListaQuartos}"
                    SelectedItem="{Binding QuartoSelecionado}"
                    ItemDisplayBinding="{Binding NomeQuarto}"
                    TextColor="Black" TitleColor="#666666" BackgroundColor="Transparent" />

            <Label Text="{Binding DescricaoQuartoSelecionado}"
                   TextColor="#666666" FontSize="14"
                   IsVisible="{Binding TemQuartoSelecionado}" />

            <Label Text="{Binding PrecoQuartoSelecionado}"
                   TextColor="Black" FontSize="14" FontAttributes="Bold"
                   IsVisible="{Binding TemQuartoSelecionado}" />

            <!-- Botões -->
            <Button Text="Calcular Reserva"
                    Clicked="OnCalcularClicked"
                    BackgroundColor="Black"
                    TextColor="White"
                    FontAttributes="Bold"
                    Margin="0,25,0,0"
                    HeightRequest="50" />

            <Frame x:Name="ResultadoFrame" BackgroundColor="#F0F0F0" IsVisible="False" HasShadow="False" BorderColor="Black" Margin="0,10,0,0">
                <Label x:Name="ResultadoLabel" FontSize="16" TextColor="Black" HorizontalTextAlignment="Center" />
            </Frame>

            <Button Text="Sobre o Desenvolvedor"
                    Clicked="OnBotaoSobreClicked"
                    BackgroundColor="Transparent"
                    TextColor="Black"
                    BorderColor="Black"
                    BorderWidth="1"
                    Margin="0,10,0,30"
                    HeightRequest="50" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>