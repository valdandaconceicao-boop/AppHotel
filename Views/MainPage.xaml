<?xml version="1.0" encoding="UTF-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppHotel.Views.MainPage"
             Title="App Hotel"
             BackgroundColor="#F5F5F7">

    <ScrollView>
        <VerticalStackLayout Spacing="15" Padding="15">

            <!-- ═══ CABEÇALHO ═══════════════════════════════════════════════ -->
            <Frame BackgroundColor="#512BD4"
                   CornerRadius="10"
                   HasShadow="False"
                   Padding="20">
                <VerticalStackLayout Spacing="5">
                    <Label Text="🏨 App Hotel"
                           FontSize="28"
                           FontAttributes="Bold"
                           TextColor="White"
                           HorizontalOptions="Center" />
                    <Label Text="Reserve seu quarto com facilidade"
                           FontSize="14"
                           TextColor="#C9B8FF"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Frame>

            <!-- ── Card: Dados do Hóspede ─────────────────────────────── -->
            <Frame BackgroundColor="White"
                   CornerRadius="10"
                   Padding="15"
                   HasShadow="True">
                <VerticalStackLayout Spacing="10">

                    <Label Text="👤 Dados do Hóspede"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="#1C1C1E" />

                    <Entry Placeholder="Nome completo *"
                           Text="{Binding Nome}" />

                    <Entry Placeholder="E-mail"
                           Text="{Binding Email}"
                           Keyboard="Email" />

                    <Entry Placeholder="Telefone"
                           Text="{Binding Telefone}"
                           Keyboard="Telephone" />

                </VerticalStackLayout>
            </Frame>

            <!-- ── Card: Período ──────────────────────────────────────── -->
            <Frame BackgroundColor="White"
                   CornerRadius="10"
                   Padding="15"
                   HasShadow="True">
                <VerticalStackLayout Spacing="10">

                    <Label Text="📅 Período da Estadia"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="#1C1C1E" />

                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" RowSpacing="10" ColumnSpacing="10">
                        <Label Text="Check-in:" Grid.Row="0" Grid.Column="0" VerticalOptions="Center" TextColor="#6C6C70"/>
                        <DatePicker x:Name="CheckInPicker"
                                    Date="{Binding DataCheckIn}"
                                    MinimumDate="{Binding DataMinima}"
                                    Grid.Row="0" Grid.Column="1" />

                        <Label Text="Check-out:" Grid.Row="1" Grid.Column="0" VerticalOptions="Center" TextColor="#6C6C70"/>
                        <DatePicker x:Name="CheckOutPicker"
                                    Date="{Binding DataCheckOut}"
                                    MinimumDate="{Binding DataMinimaSaida}"
                                    Grid.Row="1" Grid.Column="1" />
                    </Grid>

                </VerticalStackLayout>
            </Frame>

            <!-- ── Card: Hóspedes ─────────────────────────────────────── -->
            <Frame BackgroundColor="White"
                   CornerRadius="10"
                   Padding="15"
                   HasShadow="True">
                <VerticalStackLayout Spacing="10">

                    <Label Text="👥 Hóspedes"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="#1C1C1E" />

                    <Grid ColumnDefinitions="*,Auto" RowSpacing="10">
                        <Label Text="Adultos:" VerticalOptions="Center" Grid.Row="0" Grid.Column="0" TextColor="#6C6C70"/>
                        <HorizontalStackLayout Grid.Row="0" Grid.Column="1" Spacing="10" VerticalOptions="Center">
                            <Label Text="{Binding QuantidadeAdultos}" VerticalOptions="Center" FontSize="18" FontAttributes="Bold" TextColor="#512BD4" />
                            <Stepper Value="{Binding QuantidadeAdultos}" Minimum="1" Maximum="10" />
                        </HorizontalStackLayout>
                        
                        <BoxView HeightRequest="1" Color="#F0F0F0" Grid.Row="1" Grid.ColumnSpan="2" />

                        <Label Text="Crianças:" VerticalOptions="Center" Grid.Row="2" Grid.Column="0" TextColor="#6C6C70"/>
                        <HorizontalStackLayout Grid.Row="2" Grid.Column="1" Spacing="10" VerticalOptions="Center">
                            <Label Text="{Binding QuantidadeCriancas}" VerticalOptions="Center" FontSize="18" FontAttributes="Bold" TextColor="#512BD4" />
                            <Stepper Value="{Binding QuantidadeCriancas}" Minimum="0" Maximum="5" />
                        </HorizontalStackLayout>
                    </Grid>

                </VerticalStackLayout>
            </Frame>

            <!-- ── Card: Tipo de Quarto ───────────────────────────────── -->
            <Frame BackgroundColor="White"
                   CornerRadius="10"
                   Padding="15"
                   HasShadow="True">
                <VerticalStackLayout Spacing="10">

                    <Label Text="🛏️ Tipo de Quarto"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="#1C1C1E" />

                    <Picker Title="Selecione o quarto *"
                            ItemsSource="{Binding ListaQuartos}"
                            SelectedItem="{Binding QuartoSelecionado}"
                            ItemDisplayBinding="{Binding NomeQuarto}" />

                    <Label Text="{Binding DescricaoQuartoSelecionado}"
                           TextColor="#6C6C70"
                           FontSize="14"
                           IsVisible="{Binding TemQuartoSelecionado}" />

                    <Label Text="{Binding PrecoQuartoSelecionado}"
                           TextColor="#512BD4"
                           FontSize="14"
                           FontAttributes="Bold"
                           IsVisible="{Binding TemQuartoSelecionado}" />

                </VerticalStackLayout>
            </Frame>

            <!-- ── Botão Calcular ──────────────────────────────────────── -->
            <Button Text="Calcular Reserva"
                    Clicked="OnCalcularClicked"
                    BackgroundColor="#512BD4"
                    TextColor="White"
                    FontAttributes="Bold"
                    FontSize="16"
                    CornerRadius="10"
                    HeightRequest="50" />

            <!-- ── Card: Resultado (oculto até calcular) ──────────────── -->
            <Frame x:Name="ResultadoFrame"
                   BackgroundColor="White"
                   CornerRadius="10"
                   Padding="15"
                   HasShadow="True"
                   IsVisible="False">
                <Label x:Name="ResultadoLabel"
                       FontSize="16"
                       HorizontalTextAlignment="Center"
                       LineHeight="1.5" />
            </Frame>

            <!-- ── Botão Sobre ─────────────────────────────────────────── -->
            <Button Text="Sobre o Desenvolvedor"
                    Clicked="OnBotaoSobreClicked"
                    BackgroundColor="Transparent"
                    TextColor="#512BD4"
                    BorderColor="#512BD4"
                    BorderWidth="1"
                    CornerRadius="10"
                    HeightRequest="45"
                    Margin="0,0,0,20" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>