<?xml version="1.0" encoding="UTF-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppHotel.Views.MainPage"
             Title="App Hotel"
             BackgroundColor="{StaticResource Background}">

    <ScrollView>
        <VerticalStackLayout Spacing="0" Padding="20">

            <!-- Header -->
            <VerticalStackLayout Spacing="2" Margin="0,8,0,20" HorizontalOptions="Center">
                <Label Text="App Hotel"
                       FontSize="30"
                       FontAttributes="Bold"
                       TextColor="{StaticResource Primary}"
                       FontFamily="OpenSansSemibold"
                       HorizontalOptions="Center" />
                <Label Text="Simule sua reserva de forma rapida e facil"
                       FontSize="14"
                       TextColor="{StaticResource TextSecondary}"
                       HorizontalOptions="Center" />
            </VerticalStackLayout>

            <!-- Card: Dados do Hospede -->
            <Border StrokeShape="RoundRectangle 14"
                    Stroke="{StaticResource Border}"
                    StrokeThickness="1"
                    BackgroundColor="{StaticResource CardBackground}"
                    Padding="18"
                    Margin="0,0,0,14">
                <Border.Shadow>
                    <Shadow Brush="#15000000" Offset="0,2" Radius="8" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="10">
                    <Label Text="Dados do Hospede"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="{StaticResource Primary}"
                           FontFamily="OpenSansSemibold" />

                    <Entry Placeholder="Nome completo *"
                           Text="{Binding Nome}" />

                    <Entry Placeholder="E-mail"
                           Text="{Binding Email}"
                           Keyboard="Email" />

                    <Entry Placeholder="Telefone"
                           Text="{Binding Telefone}"
                           Keyboard="Telephone" />
                </VerticalStackLayout>
            </Border>

            <!-- Card: Periodo da Estadia -->
            <Border StrokeShape="RoundRectangle 14"
                    Stroke="{StaticResource Border}"
                    StrokeThickness="1"
                    BackgroundColor="{StaticResource CardBackground}"
                    Padding="18"
                    Margin="0,0,0,14">
                <Border.Shadow>
                    <Shadow Brush="#15000000" Offset="0,2" Radius="8" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="10">
                    <Label Text="Periodo da Estadia"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="{StaticResource Primary}"
                           FontFamily="OpenSansSemibold" />

                    <Grid ColumnDefinitions="100, *" RowDefinitions="Auto, Auto"
                          RowSpacing="10" ColumnSpacing="12">
                        <Label Text="Check-in"
                               VerticalOptions="Center"
                               TextColor="{StaticResource TextSecondary}"
                               FontSize="15"
                               FontFamily="OpenSansSemibold"
                               Grid.Row="0" Grid.Column="0" />
                        <DatePicker Date="{Binding DataCheckIn}"
                                    MinimumDate="{Binding DataMinima}"
                                    Format="dd/MM/yyyy"
                                    Grid.Row="0" Grid.Column="1" />

                        <Label Text="Check-out"
                               VerticalOptions="Center"
                               TextColor="{StaticResource TextSecondary}"
                               FontSize="15"
                               FontFamily="OpenSansSemibold"
                               Grid.Row="1" Grid.Column="0" />
                        <DatePicker Date="{Binding DataCheckOut}"
                                    MinimumDate="{Binding DataMinimaSaida}"
                                    Format="dd/MM/yyyy"
                                    Grid.Row="1" Grid.Column="1" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Card: Hospedes -->
            <Border StrokeShape="RoundRectangle 14"
                    Stroke="{StaticResource Border}"
                    StrokeThickness="1"
                    BackgroundColor="{StaticResource CardBackground}"
                    Padding="18"
                    Margin="0,0,0,14">
                <Border.Shadow>
                    <Shadow Brush="#15000000" Offset="0,2" Radius="8" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="14">
                    <Label Text="Hospedes"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="{StaticResource Primary}"
                           FontFamily="OpenSansSemibold" />

                    <!-- Adultos -->
                    <Grid ColumnDefinitions="*, Auto, Auto, Auto" ColumnSpacing="8">
                        <Label Text="Adultos" VerticalOptions="Center"
                               FontSize="15" TextColor="{StaticResource TextPrimary}"
                               FontFamily="OpenSansSemibold" Grid.Column="0" />
                        <Button Text="-"
                                Clicked="OnDecrementarAdultos"
                                WidthRequest="44" HeightRequest="44"
                                FontSize="22" FontAttributes="Bold"
                                TextColor="{StaticResource Primary}"
                                BackgroundColor="{StaticResource StepperBackground}"
                                CornerRadius="10"
                                Padding="0"
                                Grid.Column="1" />
                        <Label x:Name="LblAdultos"
                               Text="{Binding QuantidadeAdultos}"
                               FontSize="22" FontAttributes="Bold"
                               TextColor="{StaticResource Accent}"
                               FontFamily="OpenSansSemibold"
                               WidthRequest="44"
                               HorizontalTextAlignment="Center"
                               VerticalOptions="Center"
                               Grid.Column="2" />
                        <Button Text="+"
                                Clicked="OnIncrementarAdultos"
                                WidthRequest="44" HeightRequest="44"
                                FontSize="22" FontAttributes="Bold"
                                TextColor="White"
                                BackgroundColor="{StaticResource Primary}"
                                CornerRadius="10"
                                Padding="0"
                                Grid.Column="3" />
                    </Grid>

                    <BoxView HeightRequest="1" Color="{StaticResource Divider}" />

                    <!-- Criancas -->
                    <Grid ColumnDefinitions="*, Auto, Auto, Auto" ColumnSpacing="8">
                        <Label Text="Criancas" VerticalOptions="Center"
                               FontSize="15" TextColor="{StaticResource TextPrimary}"
                               FontFamily="OpenSansSemibold" Grid.Column="0" />
                        <Button Text="-"
                                Clicked="OnDecrementarCriancas"
                                WidthRequest="44" HeightRequest="44"
                                FontSize="22" FontAttributes="Bold"
                                TextColor="{StaticResource Primary}"
                                BackgroundColor="{StaticResource StepperBackground}"
                                CornerRadius="10"
                                Padding="0"
                                Grid.Column="1" />
                        <Label x:Name="LblCriancas"
                               Text="{Binding QuantidadeCriancas}"
                               FontSize="22" FontAttributes="Bold"
                               TextColor="{StaticResource Accent}"
                               FontFamily="OpenSansSemibold"
                               WidthRequest="44"
                               HorizontalTextAlignment="Center"
                               VerticalOptions="Center"
                               Grid.Column="2" />
                        <Button Text="+"
                                Clicked="OnIncrementarCriancas"
                                WidthRequest="44" HeightRequest="44"
                                FontSize="22" FontAttributes="Bold"
                                TextColor="White"
                                BackgroundColor="{StaticResource Primary}"
                                CornerRadius="10"
                                Padding="0"
                                Grid.Column="3" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Card: Tipo de Quarto -->
            <Border StrokeShape="RoundRectangle 14"
                    Stroke="{StaticResource Border}"
                    StrokeThickness="1"
                    BackgroundColor="{StaticResource CardBackground}"
                    Padding="18"
                    Margin="0,0,0,14">
                <Border.Shadow>
                    <Shadow Brush="#15000000" Offset="0,2" Radius="8" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="10">
                    <Label Text="Tipo de Quarto"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="{StaticResource Primary}"
                           FontFamily="OpenSansSemibold" />

                    <Picker x:Name="QuartoPicker"
                            ItemsSource="{Binding ListaQuartos}"
                            SelectedItem="{Binding QuartoSelecionado}"
                            ItemDisplayBinding="{Binding NomeQuarto}" />

                    <Label Text="{Binding DescricaoQuartoSelecionado}"
                           TextColor="{StaticResource TextSecondary}"
                           FontSize="13"
                           FontAttributes="Italic"
                           IsVisible="{Binding TemQuartoSelecionado}" />

                    <Label Text="{Binding PrecoQuartoSelecionado}"
                           TextColor="{StaticResource Accent}"
                           FontSize="15"
                           FontAttributes="Bold"
                           IsVisible="{Binding TemQuartoSelecionado}" />
                </VerticalStackLayout>
            </Border>

            <!-- Botao Calcular -->
            <Button Text="Calcular Reserva"
                    Clicked="OnCalcularClicked"
                    TextColor="White"
                    BackgroundColor="{StaticResource Primary}"
                    FontFamily="OpenSansSemibold"
                    FontSize="16"
                    FontAttributes="Bold"
                    CornerRadius="12"
                    HeightRequest="52"
                    Margin="0,4,0,0"
                    HorizontalOptions="Fill" />

            <!-- Resultado -->
            <Border x:Name="ResultadoFrame"
                    IsVisible="False"
                    StrokeShape="RoundRectangle 14"
                    StrokeThickness="2"
                    BackgroundColor="{StaticResource CardBackground}"
                    Padding="18"
                    Margin="0,14,0,0">
                <VerticalStackLayout Spacing="10">
                    <Label x:Name="ResultadoLabel"
                           FontSize="15"
                           LineBreakMode="WordWrap" />
                    <Button x:Name="BtnNovaReserva"
                            Text="Nova Reserva"
                            Clicked="OnNovaReservaClicked"
                            TextColor="{StaticResource Primary}"
                            BackgroundColor="Transparent"
                            BorderColor="{StaticResource Primary}"
                            BorderWidth="1.5"
                            FontFamily="OpenSansSemibold"
                            FontSize="15"
                            CornerRadius="12"
                            HeightRequest="48"
                            IsVisible="False"
                            HorizontalOptions="Fill" />
                </VerticalStackLayout>
            </Border>

            <!-- Botao Sobre -->
            <Button Text="Sobre o Desenvolvedor"
                    Clicked="OnBotaoSobreClicked"
                    TextColor="{StaticResource TextSecondary}"
                    BackgroundColor="Transparent"
                    BorderColor="{StaticResource Border}"
                    BorderWidth="1.5"
                    FontFamily="OpenSansSemibold"
                    FontSize="15"
                    CornerRadius="12"
                    HeightRequest="48"
                    Margin="0,14,0,24"
                    HorizontalOptions="Fill" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>