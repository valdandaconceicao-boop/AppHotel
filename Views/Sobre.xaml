<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppHotel.Views.Sobre"
             Title="Sobre o Desenvolvedor">

    <VerticalStackLayout Spacing="15"
                         Padding="30"
                         VerticalOptions="Center"
                         HorizontalOptions="Center">

        <Image Source="minha_foto.png"
               WidthRequest="150"
               HeightRequest="150"
               Aspect="AspectFit"
               HorizontalOptions="Center" />

        <Label Text="Desenvolvedor:"
               FontSize="18"
               TextColor="Gray"
               HorizontalOptions="Center" />

        <Label x:Name="NomeLabel"
               Text="Valdan Conceição Fraça"
               FontSize="24"
               FontAttributes="Bold"
               HorizontalOptions="Center" />

        <BoxView HeightRequest="1" Color="LightGray" Margin="0, 10" />

        <Label Text="Ano de Desenvolvimento: 2026"
               FontSize="16"
               HorizontalOptions="Center" />

        <Button Text="Voltar"
                Clicked="OnVoltarClicked"
                WidthRequest="200"
                Margin="0, 20, 0, 0"
                BackgroundColor="#2B0B98"
                TextColor="White"/>

    </VerticalStackLayout>
</ContentPage>