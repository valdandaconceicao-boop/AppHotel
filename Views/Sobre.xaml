<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppHotel.Views.Sobre"
             Title="Sobre"
             BackgroundColor="#F5F5F7">

    <VerticalStackLayout Spacing="0">

        <!-- ═══ CABEÇALHO COM AVATAR ════════════════════════════════════════ -->
        <Frame BackgroundColor="#512BD4"
               CornerRadius="0"
               HasShadow="False"
               Padding="24,48,24,32">
            <VerticalStackLayout Spacing="14" HorizontalOptions="Center">

                <!-- Avatar circular: Frame com CornerRadius = metade do tamanho -->
                <Frame CornerRadius="60"
                       WidthRequest="120"
                       HeightRequest="120"
                       Padding="0"
                       IsClippedToBounds="True"
                       BorderColor="White"
                       HasShadow="True"
                       HorizontalOptions="Center">
                    <Image Source="minha_foto.png"
                           Aspect="AspectFill"
                           WidthRequest="120"
                           HeightRequest="120" />
                </Frame>

                <Label Text="Valdan Conceição Fraça"
                       FontSize="22"
                       FontAttributes="Bold"
                       TextColor="White"
                       HorizontalOptions="Center" />

                <Label Text="Desenvolvedor .NET MAUI"
                       FontSize="14"
                       TextColor="#C9B8FF"
                       HorizontalOptions="Center" />

            </VerticalStackLayout>
        </Frame>

        <!-- ═══ CARDS DE INFORMAÇÃO ══════════════════════════════════════════ -->
        <VerticalStackLayout Spacing="12" Padding="16,24,16,16">

            <Frame BackgroundColor="White" CornerRadius="14" Padding="16" HasShadow="True">
                <Grid ColumnDefinitions="36,*" ColumnSpacing="12">
                    <Label Text="📅" FontSize="22" Grid.Column="0" VerticalOptions="Center" />
                    <VerticalStackLayout Grid.Column="1" Spacing="2">
                        <Label Text="Ano de Desenvolvimento" FontSize="12" TextColor="#6C6C70" />
                        <Label Text="2026" FontSize="16" FontAttributes="Bold" TextColor="#1C1C1E" />
                    </VerticalStackLayout>
                </Grid>
            </Frame>

            <Frame BackgroundColor="White" CornerRadius="14" Padding="16" HasShadow="True">
                <Grid ColumnDefinitions="36,*" ColumnSpacing="12">
                    <Label Text="🎓" FontSize="22" Grid.Column="0" VerticalOptions="Center" />
                    <VerticalStackLayout Grid.Column="1" Spacing="2">
                        <Label Text="Disciplina" FontSize="12" TextColor="#6C6C70" />
                        <Label Text="Desenvolvimento Mobile — Agenda 13" FontSize="16" FontAttributes="Bold" TextColor="#1C1C1E" />
                    </VerticalStackLayout>
                </Grid>
            </Frame>

            <Frame BackgroundColor="White" CornerRadius="14" Padding="16" HasShadow="True">
                <Grid ColumnDefinitions="36,*" ColumnSpacing="12">
                    <Label Text="💻" FontSize="22" Grid.Column="0" VerticalOptions="Center" />
                    <VerticalStackLayout Grid.Column="1" Spacing="2">
                        <Label Text="Tecnologia" FontSize="12" TextColor="#6C6C70" />
                        <Label Text=".NET MAUI (C#)" FontSize="16" FontAttributes="Bold" TextColor="#1C1C1E" />
                    </VerticalStackLayout>
                </Grid>
            </Frame>

        </VerticalStackLayout>

        <!-- ═══ BOTÃO VOLTAR ═════════════════════════════════════════════════ -->
        <Button Text="← Voltar"
                Clicked="OnVoltarClicked"
                BackgroundColor="#512BD4"
                TextColor="White"
                FontAttributes="Bold"
                CornerRadius="12"
                HeightRequest="50"
                Margin="16,8,16,32" />

    </VerticalStackLayout>

</ContentPage>