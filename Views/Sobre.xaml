<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppHotel.Views.Sobre"
             Title="Sobre"
             BackgroundColor="{StaticResource Background}">

    <ScrollView>
        <VerticalStackLayout Spacing="0" Padding="20">

            <VerticalStackLayout Spacing="2" Margin="0,16,0,20" HorizontalOptions="Center">
                <Label Text="Sobre o Desenvolvedor"
                       FontSize="28"
                       FontAttributes="Bold"
                       TextColor="{StaticResource Primary}"
                       FontFamily="OpenSansSemibold"
                       HorizontalOptions="Center" />
            </VerticalStackLayout>

            <!-- Card: Perfil -->
            <Border StrokeShape="RoundRectangle 14"
                    Stroke="{StaticResource Border}"
                    StrokeThickness="1"
                    BackgroundColor="{StaticResource CardBackground}"
                    Padding="28"
                    Margin="0,0,0,14">
                <Border.Shadow>
                    <Shadow Brush="#15000000" Offset="0,2" Radius="8" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="14" HorizontalOptions="Center">
                    <Border StrokeShape="RoundRectangle 75"
                            Stroke="{StaticResource Accent}"
                            StrokeThickness="3"
                            WidthRequest="150"
                            HeightRequest="150"
                            HorizontalOptions="Center"
                            BackgroundColor="{StaticResource InputBackground}"
                            Padding="0">
<Image Source="minha_foto.png"
                       WidthRequest="150"
                       HeightRequest="150"
                       Aspect="AspectFill">
                        <Image.Clip>
                            <EllipseGeometry Center="75,75" RadiusX="75" RadiusY="75" />
                        </Image.Clip>
                    </Image>
                </Border>

                    <Label Text="Valdan Conceição Fraça"
                           FontSize="22"
                           FontAttributes="Bold"
                           TextColor="{StaticResource TextPrimary}"
                           FontFamily="OpenSansSemibold"
                           HorizontalOptions="Center" />

                    <Label Text="Desenvolvedor .NET MAUI"
                           FontSize="15"
                           TextColor="{StaticResource Accent}"
                           FontFamily="OpenSansSemibold"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Border>

            <!-- Card: Projeto -->
            <Border StrokeShape="RoundRectangle 14"
                    Stroke="{StaticResource Border}"
                    StrokeThickness="1"
                    BackgroundColor="{StaticResource CardBackground}"
                    Padding="18"
                    Margin="0,0,0,14">
                <Border.Shadow>
                    <Shadow Brush="#15000000" Offset="0,2" Radius="8" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="10">
                    <Label Text="Projeto"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="{StaticResource Primary}"
                           FontFamily="OpenSansSemibold" />

                    <BoxView HeightRequest="1" Color="{StaticResource Divider}" />

                    <Grid ColumnDefinitions="100, *" RowDefinitions="Auto, Auto"
                          RowSpacing="10" ColumnSpacing="12">
                        <Label Text="Aplicativo" FontSize="14"
                               TextColor="{StaticResource TextSecondary}"
                               FontFamily="OpenSansSemibold"
                               Grid.Row="0" Grid.Column="0" />
                        <Label Text="App Hotel (Agenda 13)" FontSize="14"
                               TextColor="{StaticResource TextPrimary}"
                               Grid.Row="0" Grid.Column="1" />
                        <Label Text="Ano" FontSize="14"
                               TextColor="{StaticResource TextSecondary}"
                               FontFamily="OpenSansSemibold"
                               Grid.Row="1" Grid.Column="0" />
                        <Label Text="2026" FontSize="14"
                               TextColor="{StaticResource TextPrimary}"
                               Grid.Row="1" Grid.Column="1" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Botão Voltar -->
            <Button Text="Voltar"
                    Clicked="OnVoltarClicked"
                    TextColor="White"
                    BackgroundColor="{StaticResource Primary}"
                    FontFamily="OpenSansSemibold"
                    FontSize="16"
                    FontAttributes="Bold"
                    CornerRadius="12"
                    HeightRequest="52"
                    Margin="0,4,0,24"
                    HorizontalOptions="Fill" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>