<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppHotel.Views.Sobre"
             Title="Sobre o Desenvolvedor"
             BackgroundColor="White">

    <VerticalStackLayout Spacing="20" Padding="30" VerticalOptions="Center">

        <Image Source="minha_foto.png"
               WidthRequest="150"
               HeightRequest="150"
               Aspect="AspectFill"
               HorizontalOptions="Center">
            <Image.Clip>
                <EllipseGeometry Center="75,75" RadiusX="75" RadiusY="75" />
            </Image.Clip>
        </Image>

        <Label Text="Valdan Conceição Fraça"
               FontSize="24"
               FontAttributes="Bold"
               TextColor="Black"
               HorizontalOptions="Center" />

        <Label Text="Desenvolvedor .NET MAUI"
               FontSize="16"
               TextColor="#666666"
               HorizontalOptions="Center" />

        <BoxView HeightRequest="1" Color="LightGray" Margin="0,15" />

        <Label Text="Projeto: App Hotel (Agenda 13)"
               FontSize="16"
               TextColor="Black"
               HorizontalOptions="Center" />

        <Label Text="Ano: 2026"
               FontSize="16"
               TextColor="Black"
               HorizontalOptions="Center" />

        <Button Text="Voltar"
                Clicked="OnVoltarClicked"
                BackgroundColor="Black"
                TextColor="White"
                FontAttributes="Bold"
                Margin="0,30,0,0"
                HeightRequest="50"
                WidthRequest="200"
                HorizontalOptions="Center" />

    </VerticalStackLayout>

</ContentPage>