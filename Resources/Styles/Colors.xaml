<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Color x:Key="Primary">#1B4332</Color>
    <Color x:Key="PrimaryLight">#2D6A4F</Color>
    <Color x:Key="PrimaryDark">#081C15</Color>
    <Color x:Key="Accent">#C2762B</Color>
    <Color x:Key="AccentLight">#E9C89B</Color>
    <Color x:Key="White">White</Color>
    <Color x:Key="Black">#111111</Color>
    <Color x:Key="Background">#F0EDE6</Color>
    <Color x:Key="CardBackground">White</Color>
    <Color x:Key="TextPrimary">#111111</Color>
    <Color x:Key="TextSecondary">#555555</Color>
    <Color x:Key="TextMuted">#888888</Color>
    <Color x:Key="Border">#D4CFC5</Color>
    <Color x:Key="InputBackground">#FFFFFF</Color>
    <Color x:Key="InputPlaceholder">#999999</Color>
    <Color x:Key="Success">#166534</Color>
    <Color x:Key="SuccessLight">#F0FDF4</Color>
    <Color x:Key="SuccessBorder">#86EFAC</Color>
    <Color x:Key="Warning">#92400E</Color>
    <Color x:Key="WarningLight">#FFFBEB</Color>
    <Color x:Key="WarningBorder">#FCD34D</Color>
    <Color x:Key="Divider">#E8E4DC</Color>
    <Color x:Key="StepperBackground">#B0ABA2</Color>
    <Color x:Key="NavBackground">#1B4332</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Accent}" />
</ResourceDictionary>